  notes       String?
  createdBy   String?             @map("created_by") @db.Uuid

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  warranty Warranty? @relation(fields: [warrantyId], references: [id])
  creator  User?     @relation("WarrantyClaimCreatedBy", fields: [createdBy], references: [id])

  @@map("warranty_claims")
}

// ---------- (6) HR ----------

model Employee {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  branchId       String?  @map("branch_id") @db.Uuid
  userId         String?  @unique @map("user_id") @db.Uuid
  fullName       String   @map("full_name") @db.VarChar(150)
  jobTitle       String?  @map("job_title") @db.VarChar(80)
  phone          String?  @db.VarChar(30)
  salary         Decimal  @default(0) @db.Decimal(12, 3)
  commissionRate Decimal  @default(0) @map("commission_rate") @db.Decimal(5, 2)
  hiredAt        DateTime? @map("hired_at") @db.Date
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz

  tenant     Tenant       @relation(fields: [tenantId], references: [id])
  branch     Branch?      @relation(fields: [branchId], references: [id])
  user       User?        @relation(fields: [userId], references: [id])
  attendance Attendance[]
  tasks      Task[]
  payrolls   Payroll[]

  @@map("employees")
}

model Attendance {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  employeeId String?   @map("employee_id") @db.Uuid
  checkIn    DateTime? @map("check_in") @db.Timestamptz
  checkOut   DateTime? @map("check_out") @db.Timestamptz
  workDate   DateTime  @default(now()) @map("work_date") @db.Date
  location   String?

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  employee Employee? @relation(fields: [employeeId], references: [id])

  @@map("attendance")
}

model Task {
  id          String     @id @default(uuid()) @db.Uuid
  tenantId    String     @map("tenant_id") @db.Uuid
  branchId    String?    @map("branch_id") @db.Uuid
  title       String     @db.VarChar(200)
  description String?
  assignedTo  String?    @map("assigned_to") @db.Uuid
  status      TaskStatus @default(new)
  dueDate     DateTime?  @map("due_date") @db.Date
  createdBy   String?    @map("created_by") @db.Uuid
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  branch   Branch?   @relation(fields: [branchId], references: [id])
  assignee Employee? @relation(fields: [assignedTo], references: [id])
  creator  User?     @relation("TaskCreatedBy", fields: [createdBy], references: [id])

  @@map("tasks")
}

model Payroll {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  employeeId String?  @map("employee_id") @db.Uuid
  period     String?  @db.VarChar(7)
  base       Decimal? @db.Decimal(12, 3)
  commission Decimal  @default(0) @db.Decimal(12, 3)
  deductions Decimal  @default(0) @db.Decimal(12, 3)
  net        Decimal? @db.Decimal(12, 3)
  paid       Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  employee Employee? @relation(fields: [employeeId], references: [id])

  @@map("payroll")
}

