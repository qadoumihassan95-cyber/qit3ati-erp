// =====================================================================
// Qit3ati / AutoParts Cloud — Prisma Schema
// Mirrors 02_database_schema.sql; multi-tenant via tenant_id row scoping.
// =====================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Enums ----------
enum TenantPlan {
  basic
  pro
  business
  enterprise
}

enum TenantStatus {
  trial
  active
  suspended
  cancelled
}

enum StockStatus {
  available
  low
  out
  damaged
  returned
  reserved
}

enum PaymentType {
  cash
  credit
  card
  bank
  cheque
}

enum SaleStatus {
  draft
  completed
  cancelled
}

enum PartNumberType {
  oem
  alternative
  cross
}

enum TransferStatus {
  pending
  in_transit
  received
  cancelled
}

enum PriceTier {
  retail
  wholesale
  special
}

enum AccountType {
  asset
  liability
  equity
  revenue
  expense
}

enum WarrantyResolution {
  replace
  repair
  reject
}

enum TaskStatus {
  new
  in_progress
  done
}

enum DocumentType {
  govt
  license
  certificate
  contract
  customs
  invoice
  transfer
}

enum NotificationType {
  low_stock
  doc_expiry
  security
  daily_report
  debt
  other
}

enum NotificationChannel {
  in_app
  telegram
  sms
  whatsapp
}

enum StockMovementType {
  purchase
  sale
  return_in
  return_out
  transfer
  adjust
  damage
}

// ---------- (1) Tenancy core ----------

model Tenant {
  id           String       @id @default(uuid()) @db.Uuid
  name         String       @db.VarChar(150)
  slug         String       @unique @db.VarChar(80)
  plan         TenantPlan   @default(basic)
  status       TenantStatus @default(trial)
  trialEndsAt  DateTime?    @map("trial_ends_at") @db.Date
  maxBranches  Int          @default(1) @map("max_branches")
  maxUsers     Int          @default(2) @map("max_users")
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  settings     TenantSettings?
  branches     Branch[]
  warehouses   Warehouse[]
  users        User[]
  roles        Role[]
  categories   Category[]
  carMakes     CarMake[]
  carModels    CarModel[]
  parts        Part[]
  stocks       Stock[]
  suppliers    Supplier[]
  customers    Customer[]
  purchaseInvoices PurchaseInvoice[]
  salesInvoices    SalesInvoice[]
  posSessions      PosSession[]
  quotations       Quotation[]
  accounts         ChartAccount[]
  journalEntries   JournalEntry[]
  cashBoxes        CashBox[]
  banks            Bank[]
  receipts         Receipt[]
  payments         Payment[]
  expenseCategories ExpenseCategory[]
  expenses         Expense[]
  salesReturns     SalesReturn[]
  purchaseReturns  PurchaseReturn[]
  damagedItems     DamagedItem[]
  warranties       Warranty[]
  warrantyClaims   WarrantyClaim[]
  employees        Employee[]
  attendance       Attendance[]
  tasks            Task[]
  payrolls         Payroll[]
  documents        Document[]
  notifications    Notification[]
  telegramLinks    TelegramLink[]
  transfers        Transfer[]
  auditLogs        AuditLog[]
  partNumbers      PartNumber[]
  partCompats      PartCompatibility[]
  partImages       PartImage[]
  stockMovements   StockMovement[]
  stockCounts      StockCount[]

  @@map("tenants")
}

model TenantSettings {
  tenantId        String   @id @map("tenant_id") @db.Uuid
  legalName       String?  @map("legal_name") @db.VarChar(200)
  taxNumber       String?  @map("tax_number") @db.VarChar(50)
  logoUrl         String?  @map("logo_url")
  colorPrimary    String   @default("#1E5F74") @map("color_primary") @db.VarChar(9)
  colorSecondary  String   @default("#FF7A00") @map("color_secondary") @db.VarChar(9)
  currency        String   @default("JOD") @db.VarChar(3)
  taxRate         Decimal  @default(16.00) @map("tax_rate") @db.Decimal(5, 2)
  language        String   @default("ar") @db.VarChar(5)
  invoiceHeader   String?  @map("invoice_header")
  invoiceFooter   String?  @map("invoice_footer")
  phone           String?  @db.VarChar(30)
  address         String?
  jofotaraEnabled Boolean  @default(false) @map("jofotara_enabled")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_settings")
}

model Branch {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String   @db.VarChar(120)
  code      String?  @db.VarChar(20)
  address   String?
  phone     String?  @db.VarChar(30)
  isMain    Boolean  @default(false) @map("is_main")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  warehouses  Warehouse[]
  stocks      Stock[]
  userBranches UserBranch[]
  purchaseInvoices PurchaseInvoice[]
  salesInvoices    SalesInvoice[]
  posSessions      PosSession[]
  quotations       Quotation[]
  journalEntries   JournalEntry[]
  cashBoxes        CashBox[]
  receipts         Receipt[]
  payments         Payment[]
  expenses         Expense[]
  salesReturns     SalesReturn[]
  purchaseReturns  PurchaseReturn[]
  damagedItems     DamagedItem[]
  employees        Employee[]
  tasks            Task[]
  transfersFrom    Transfer[] @relation("TransferFromBranch")
  transfersTo      Transfer[] @relation("TransferToBranch")
  stockMovements   StockMovement[]
  stockCounts      StockCount[]

  @@index([tenantId])
  @@map("branches")
}

model Warehouse {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  branchId  String   @map("branch_id") @db.Uuid
  name      String   @db.VarChar(120)
  isMain    Boolean  @default(false) @map("is_main")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  branch    Branch   @relation(fields: [branchId], references: [id])
  stocks    Stock[]

  @@index([tenantId, branchId])
  @@map("warehouses")
}

model Role {
  id       String   @id @default(uuid()) @db.Uuid
  tenantId String?  @map("tenant_id") @db.Uuid
  name     String   @db.VarChar(60)
  labelAr  String?  @map("label_ar") @db.VarChar(80)
  isSystem Boolean  @default(false) @map("is_system")

  tenant     Tenant?           @relation(fields: [tenantId], references: [id])
  users      User[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id      String  @id @default(uuid()) @db.Uuid
  code    String  @unique @db.VarChar(80)
  module  String? @db.VarChar(40)
  labelAr String? @map("label_ar") @db.VarChar(120)

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model User {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String?   @map("tenant_id") @db.Uuid
  roleId        String?   @map("role_id") @db.Uuid
  fullName      String    @map("full_name") @db.VarChar(150)
  email         String?   @db.VarChar(150)
  phone         String?   @db.VarChar(30)
  passwordHash  String    @map("password_hash")
  isSuperAdmin  Boolean   @default(false) @map("is_super_admin")
  isActive      Boolean   @default(true) @map("is_active")
  lastLoginAt   DateTime? @map("last_login_at") @db.Timestamptz
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz

  tenant         Tenant?       @relation(fields: [tenantId], references: [id])
  role           Role?         @relation(fields: [roleId], references: [id])
  userBranches   UserBranch[]
  auditLogs      AuditLog[]
  posSessions    PosSession[]
  salesInvoices  SalesInvoice[] @relation("SoldBy")
  purchaseInvoices PurchaseInvoice[] @relation("PurchaseCreatedBy")
  expensesCreated  Expense[] @relation("ExpenseCreatedBy")
  receiptsCreated  Receipt[] @relation("ReceiptCreatedBy")
  paymentsCreated  Payment[] @relation("PaymentCreatedBy")
  salesReturnsCreated  SalesReturn[] @relation("SalesReturnCreatedBy")
  purchaseReturnsCreated PurchaseReturn[] @relation("PurchaseReturnCreatedBy")
  damagedItemsCreated  DamagedItem[] @relation("DamagedItemCreatedBy")
  warrantyClaimsCreated WarrantyClaim[] @relation("WarrantyClaimCreatedBy")
  partsCreated      Part[] @relation("PartCreatedBy")
  stockMovements    StockMovement[]
  stockCounts       StockCount[]
  tasksCreated      Task[] @relation("TaskCreatedBy")
  documentsUploaded Document[]
  notifications     Notification[]
  telegramLinks     TelegramLink[]
  journalEntries    JournalEntry[]
  transfersCreated  Transfer[] @relation("TransferCreatedBy")
  transfersReceived Transfer[] @relation("TransferReceivedBy")
  employee          Employee?

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

model UserBranch {
  userId   String @map("user_id") @db.Uuid
  branchId String @map("branch_id") @db.Uuid

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@id([userId, branchId])
  @@map("user_branches")
}

model AuditLog {
  id        BigInt   @id @default(autoincrement())
  tenantId  String   @map("tenant_id") @db.Uuid
  branchId  String?  @map("branch_id") @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  action    String?  @db.VarChar(40)
  entity    String?  @db.VarChar(60)
  entityId  String?  @map("entity_id") @db.Uuid
  oldValue  Json?    @map("old_value")
  newValue  Json?    @map("new_value")
  ipAddress String?  @map("ip_address") @db.Inet
  device    String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User?  @relation(fields: [userId], references: [id])

  @@index([tenantId, createdAt])
  @@map("audit_logs")
}

// ---------- (2) Catalog & Inventory ----------

model Category {
  id       String  @id @default(uuid()) @db.Uuid
  tenantId String  @map("tenant_id") @db.Uuid
  parentId String? @map("parent_id") @db.Uuid
  name     String  @db.VarChar(120)
  nameEn   String? @map("name_en") @db.VarChar(120)

  tenant   Tenant     @relation(fields: [tenantId], references: [id])
  parent   Category?  @relation("CategoryParent", fields: [parentId], references: [id])
  children Category[] @relation("CategoryParent")
  parts    Part[]

  @@map("categories")
}

model CarMake {
  id       String  @id @default(uuid()) @db.Uuid
  tenantId String? @map("tenant_id") @db.Uuid
  name     String  @db.VarChar(80)

  tenant Tenant?    @relation(fields: [tenantId], references: [id])
  models CarModel[]
  partCompatibilities PartCompatibility[]

  @@map("car_makes")
}

model CarModel {
  id       String  @id @default(uuid()) @db.Uuid
  tenantId String? @map("tenant_id") @db.Uuid
  makeId   String? @map("make_id") @db.Uuid
  name     String  @db.VarChar(80)
  yearFrom Int?    @map("year_from")
  yearTo   Int?    @map("year_to")

  tenant Tenant?  @relation(fields: [tenantId], references: [id])
  make   CarMake? @relation(fields: [makeId], references: [id])
  partCompatibilities PartCompatibility[]

  @@map("car_models")
}

model Part {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  sku            String   @db.VarChar(60)
  name           String   @db.VarChar(200)
  nameEn         String?  @map("name_en") @db.VarChar(200)
  categoryId     String?  @map("category_id") @db.Uuid
  partNumber     String?  @map("part_number") @db.VarChar(80)
  oemNumber      String?  @map("oem_number") @db.VarChar(80)
  barcode        String?  @db.VarChar(80)
  manufacturer   String?  @db.VarChar(120)
  countryOrigin  String?  @map("country_origin") @db.VarChar(80)
  unit           String   @default("حبة") @db.VarChar(20)
  costPrice      Decimal  @default(0) @map("cost_price") @db.Decimal(12, 3)
  avgCost        Decimal  @default(0) @map("avg_cost") @db.Decimal(12, 3)
  retailPrice    Decimal  @default(0) @map("retail_price") @db.Decimal(12, 3)
  wholesalePrice Decimal  @default(0) @map("wholesale_price") @db.Decimal(12, 3)
  minStock       Decimal  @default(0) @map("min_stock") @db.Decimal(12, 2)
  maxStock       Decimal? @map("max_stock") @db.Decimal(12, 2)
  reorderPoint   Decimal? @map("reorder_point") @db.Decimal(12, 2)
  warrantyMonths Int      @default(0) @map("warranty_months")
  taxRate        Decimal  @default(16.00) @map("tax_rate") @db.Decimal(5, 2)
  isActive       Boolean  @default(true) @map("is_active")
  createdBy      String?  @map("created_by") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  category  Category? @relation(fields: [categoryId], references: [id])
  creator   User?     @relation("PartCreatedBy", fields: [createdBy], references: [id])
  numbers   PartNumber[]
  compats   PartCompatibility[]
  images    PartImage[]
  stocks    Stock[]
  movements StockMovement[]
  substitutesA  PartSubstitute[] @relation("PartA")
  substitutesB  PartSubstitute[] @relation("PartB")
  customerSpecialPrices CustomerSpecialPrice[]
  priceTiers   PartPriceTier[]
  purchaseItems PurchaseItem[]
  salesItems    SalesItem[]
  countItems    StockCountItem[]
  transferItems TransferItem[]
  salesReturnItems   SalesReturnItem[]
  purchaseReturnItems PurchaseReturnItem[]
  damagedItems  DamagedItem[]
  warranties    Warranty[]

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@index([tenantId, partNumber, oemNumber, barcode])
  @@map("parts")
}

model PartNumber {
  id         String         @id @default(uuid()) @db.Uuid
  tenantId   String         @map("tenant_id") @db.Uuid
  partId     String         @map("part_id") @db.Uuid
  number     String         @db.VarChar(80)
  numberType PartNumberType @default(alternative) @map("number_type")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  part   Part   @relation(fields: [partId], references: [id], onDelete: Cascade)

  @@index([tenantId, number])
  @@map("part_numbers")
}

model PartCompatibility {
  id        String  @id @default(uuid()) @db.Uuid
  tenantId  String  @map("tenant_id") @db.Uuid
  partId    String  @map("part_id") @db.Uuid
  makeId    String? @map("make_id") @db.Uuid
  modelId   String? @map("model_id") @db.Uuid
  yearFrom  Int?    @map("year_from")
  yearTo    Int?    @map("year_to")
  engine    String? @db.VarChar(60)

  tenant Tenant   @relation(fields: [tenantId], references: [id])
  part   Part     @relation(fields: [partId], references: [id], onDelete: Cascade)
  make   CarMake? @relation(fields: [makeId], references: [id])
  model  CarModel? @relation(fields: [modelId], references: [id])

  @@map("part_compatibility")
}

model PartSubstitute {
  partId       String @map("part_id") @db.Uuid
  substituteId String @map("substitute_id") @db.Uuid

  part       Part @relation("PartA", fields: [partId], references: [id], onDelete: Cascade)
  substitute Part @relation("PartB", fields: [substituteId], references: [id], onDelete: Cascade)

  @@id([partId, substituteId])
  @@map("part_substitutes")
}

model PartImage {
  id        String  @id @default(uuid()) @db.Uuid
  tenantId  String  @map("tenant_id") @db.Uuid
  partId    String  @map("part_id") @db.Uuid
  url       String
  isPrimary Boolean @default(false) @map("is_primary")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  part   Part   @relation(fields: [partId], references: [id], onDelete: Cascade)

  @@map("part_images")
}

model Stock {
  id         String      @id @default(uuid()) @db.Uuid
  tenantId   String      @map("tenant_id") @db.Uuid
  branchId   String      @map("branch_id") @db.Uuid
  warehouseId String?    @map("warehouse_id") @db.Uuid
  partId     String      @map("part_id") @db.Uuid
  quantity   Decimal     @default(0) @db.Decimal(12, 2)
  reserved   Decimal     @default(0) @db.Decimal(12, 2)
  location   String?     @db.VarChar(60)
  status     StockStatus @default(available)

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  branch    Branch     @relation(fields: [branchId], references: [id])
  warehouse Warehouse? @relation(fields: [warehouseId], references: [id])
  part      Part       @relation(fields: [partId], references: [id])

  @@unique([tenantId, warehouseId, partId])
  @@index([tenantId, branchId, partId])
  @@map("stock")
}

model StockMovement {
  id         BigInt            @id @default(autoincrement())
  tenantId   String            @map("tenant_id") @db.Uuid
  branchId   String            @map("branch_id") @db.Uuid
  partId     String            @map("part_id") @db.Uuid
  type       StockMovementType
  qtyChange  Decimal           @map("qty_change") @db.Decimal(12, 2)
  refTable   String?           @map("ref_table") @db.VarChar(40)
  refId      String?           @map("ref_id") @db.Uuid
  unitCost   Decimal?          @map("unit_cost") @db.Decimal(12, 3)
  userId     String?           @map("user_id") @db.Uuid
  createdAt  DateTime          @default(now()) @map("created_at") @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])
  branch Branch @relation(fields: [branchId], references: [id])
  part   Part   @relation(fields: [partId], references: [id])
  user   User?  @relation(fields: [userId], references: [id])

  @@index([tenantId, partId, createdAt])
  @@map("stock_movements")
}

model StockCount {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  branchId  String   @map("branch_id") @db.Uuid
  status    String   @default("draft") @db.VarChar(20)
  countedBy String?  @map("counted_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenant Tenant            @relation(fields: [tenantId], references: [id])
  branch Branch            @relation(fields: [branchId], references: [id])
  user   User?             @relation(fields: [countedBy], references: [id])
  items  StockCountItem[]

  @@map("stock_counts")
}

model StockCountItem {
  countId    String  @map("count_id") @db.Uuid
  partId     String  @map("part_id") @db.Uuid
  systemQty  Decimal? @map("system_qty") @db.Decimal(12, 2)
  countedQty Decimal? @map("counted_qty") @db.Decimal(12, 2)

  count StockCount @relation(fields: [countId], references: [id], onDelete: Cascade)
  part  Part       @relation(fields: [partId], references: [id])

  @@id([countId, partId])
  @@map("stock_count_items")
}

model Transfer {
  id         String         @id @default(uuid()) @db.Uuid
  tenantId   String         @map("tenant_id") @db.Uuid
  fromBranch String?        @map("from_branch") @db.Uuid
  toBranch   String?        @map("to_branch") @db.Uuid
  status     TransferStatus @default(pending)
  createdBy  String?        @map("created_by") @db.Uuid
  receivedBy String?        @map("received_by") @db.Uuid
  createdAt  DateTime       @default(now()) @map("created_at") @db.Timestamptz

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  from     Branch?  @relation("TransferFromBranch", fields: [fromBranch], references: [id])
  to       Branch?  @relation("TransferToBranch", fields: [toBranch], references: [id])
  creator  User?    @relation("TransferCreatedBy", fields: [createdBy], references: [id])
  receiver User?    @relation("TransferReceivedBy", fields: [receivedBy], references: [id])
  items    TransferItem[]

  @@map("transfers")
}

model TransferItem {
  transferId  String  @map("transfer_id") @db.Uuid
  partId      String  @map("part_id") @db.Uuid
  qtySent     Decimal? @map("qty_sent") @db.Decimal(12, 2)
  qtyReceived Decimal? @map("qty_received") @db.Decimal(12, 2)

  transfer Transfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  part     Part     @relation(fields: [partId], references: [id])

  @@id([transferId, partId])
  @@map("transfer_items")
}

// ---------- (3) Suppliers, Customers, Purchases, Sales ----------

model Supplier {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String   @db.VarChar(150)
  phone     String?  @db.VarChar(30)
  email     String?  @db.VarChar(120)
  taxNumber String?  @map("tax_number") @db.VarChar(50)
  address   String?
  balance   Decimal  @default(0) @db.Decimal(14, 3)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  tenant            Tenant            @relation(fields: [tenantId], references: [id])
  purchaseInvoices  PurchaseInvoice[]
  payments          Payment[]
  purchaseReturns   PurchaseReturn[]

  @@index([tenantId])
  @@map("suppliers")
}

model Customer {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  name        String    @db.VarChar(150)
  phone       String?   @db.VarChar(30)
  email       String?   @db.VarChar(120)
  taxNumber   String?   @map("tax_number") @db.VarChar(50)
  address     String?
  priceTier   PriceTier @default(retail) @map("price_tier")
  creditLimit Decimal   @default(0) @map("credit_limit") @db.Decimal(14, 3)
  balance     Decimal   @default(0) @db.Decimal(14, 3)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz

  tenant             Tenant   @relation(fields: [tenantId], references: [id])
  salesInvoices      SalesInvoice[]
  receipts           Receipt[]
  quotations         Quotation[]
  specialPrices      CustomerSpecialPrice[]
  warranties         Warranty[]

  @@index([tenantId])
  @@map("customers")
}

model CustomerSpecialPrice {
  customerId String  @map("customer_id") @db.Uuid
  partId     String  @map("part_id") @db.Uuid
  price      Decimal @db.Decimal(12, 3)

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  part     Part     @relation(fields: [partId], references: [id], onDelete: Cascade)

  @@id([customerId, partId])
  @@map("customer_special_prices")
}

model PartPriceTier {
  id       String   @id @default(uuid()) @db.Uuid
