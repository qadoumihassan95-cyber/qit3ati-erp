  items    PurchaseItem[]
  returns  PurchaseReturn[]

  @@index([tenantId, branchId, invoiceDate])
  @@map("purchase_invoices")
}

model PurchaseItem {
  id        String  @id @default(uuid()) @db.Uuid
  invoiceId String  @map("invoice_id") @db.Uuid
  partId    String? @map("part_id") @db.Uuid
  qty       Decimal? @db.Decimal(12, 2)
  unitCost  Decimal? @map("unit_cost") @db.Decimal(12, 3)
  lineTotal Decimal? @map("line_total") @db.Decimal(14, 3)

  invoice PurchaseInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  part    Part?           @relation(fields: [partId], references: [id])

  @@map("purchase_items")
}

model PosSession {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  branchId    String    @map("branch_id") @db.Uuid
  userId      String?   @map("user_id") @db.Uuid
  openingCash Decimal   @default(0) @map("opening_cash") @db.Decimal(14, 3)
  closingCash Decimal?  @map("closing_cash") @db.Decimal(14, 3)
  openedAt    DateTime  @default(now()) @map("opened_at") @db.Timestamptz
  closedAt    DateTime? @map("closed_at") @db.Timestamptz
  status      String    @default("open") @db.VarChar(20)

  tenant Tenant @relation(fields: [tenantId], references: [id])
  branch Branch @relation(fields: [branchId], references: [id])
  user   User?  @relation(fields: [userId], references: [id])
  salesInvoices SalesInvoice[]

  @@map("pos_sessions")
}

model SalesInvoice {
  id            String       @id @default(uuid()) @db.Uuid
  tenantId      String       @map("tenant_id") @db.Uuid
  branchId      String       @map("branch_id") @db.Uuid
  posSessionId  String?      @map("pos_session_id") @db.Uuid
  customerId    String?      @map("customer_id") @db.Uuid
  invoiceNo     String?      @map("invoice_no") @db.VarChar(40)
  invoiceDate   DateTime     @default(now()) @map("invoice_date") @db.Date
  subtotal      Decimal      @default(0) @db.Decimal(14, 3)
  discount      Decimal      @default(0) @db.Decimal(14, 3)
  tax           Decimal      @default(0) @db.Decimal(14, 3)
  total         Decimal      @default(0) @db.Decimal(14, 3)
  paid          Decimal      @default(0) @db.Decimal(14, 3)
  paymentType   PaymentType  @default(cash) @map("payment_type")
  status        SaleStatus   @default(completed)
  jofotaraUuid  String?      @map("jofotara_uuid") @db.VarChar(60)
  jofotaraQr    String?      @map("jofotara_qr")
  soldBy        String?      @map("sold_by") @db.Uuid
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz
  deletedAt     DateTime?    @map("deleted_at") @db.Timestamptz

  tenant     Tenant       @relation(fields: [tenantId], references: [id])
  branch     Branch       @relation(fields: [branchId], references: [id])
  posSession PosSession?  @relation(fields: [posSessionId], references: [id])
  customer   Customer?    @relation(fields: [customerId], references: [id])
  seller     User?        @relation("SoldBy", fields: [soldBy], references: [id])
  items      SalesItem[]
  returns    SalesReturn[]

  @@index([tenantId, branchId, invoiceDate])
  @@map("sales_invoices")
}

model SalesItem {
  id            String   @id @default(uuid()) @db.Uuid
  invoiceId     String   @map("invoice_id") @db.Uuid
  partId        String?  @map("part_id") @db.Uuid
  qty           Decimal? @db.Decimal(12, 2)
  unitPrice     Decimal? @map("unit_price") @db.Decimal(12, 3)
  unitCost      Decimal? @map("unit_cost") @db.Decimal(12, 3)
  discount      Decimal  @default(0) @db.Decimal(12, 3)
  lineTotal     Decimal? @map("line_total") @db.Decimal(14, 3)
  warrantyUntil DateTime? @map("warranty_until") @db.Date

  invoice    SalesInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  part       Part?        @relation(fields: [partId], references: [id])
  warranties Warranty[]

  @@map("sales_items")
}

model Quotation {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  branchId   String?  @map("branch_id") @db.Uuid
  customerId String?  @map("customer_id") @db.Uuid
  total      Decimal? @db.Decimal(14, 3)
  validUntil DateTime? @map("valid_until") @db.Date
