  price    Decimal? @db.Decimal(12, 3)

  part Part? @relation(fields: [partId], references: [id], onDelete: Cascade)

  @@map("price_tiers")
}

model PurchaseInvoice {
  id            String       @id @default(uuid()) @db.Uuid
  tenantId      String       @map("tenant_id") @db.Uuid
  branchId      String       @map("branch_id") @db.Uuid
  supplierId    String?      @map("supplier_id") @db.Uuid
  invoiceNo     String?      @map("invoice_no") @db.VarChar(40)
  supplierRef   String?      @map("supplier_ref") @db.VarChar(60)
  invoiceDate   DateTime     @default(now()) @map("invoice_date") @db.Date
  subtotal      Decimal      @default(0) @db.Decimal(14, 3)
  tax           Decimal      @default(0) @db.Decimal(14, 3)
  total         Decimal      @default(0) @db.Decimal(14, 3)
  paid          Decimal      @default(0) @db.Decimal(14, 3)
  paymentType   PaymentType  @default(cash) @map("payment_type")
  status        String       @default("received") @db.VarChar(20)
  attachmentUrl String?      @map("attachment_url")
  createdBy     String?      @map("created_by") @db.Uuid
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz
  deletedAt     DateTime?    @map("deleted_at") @db.Timestamptz

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  branch   Branch    @relation(fields: [branchId], references: [id])
