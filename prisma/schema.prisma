  chequeNo    String?     @map("cheque_no") @db.VarChar(40)
  chequeDate  DateTime?   @map("cheque_date") @db.Date
  receiptDate DateTime    @default(now()) @map("receipt_date") @db.Date
  createdBy   String?     @map("created_by") @db.Uuid
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  branch   Branch?   @relation(fields: [branchId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])
  creator  User?     @relation("ReceiptCreatedBy", fields: [createdBy], references: [id])

