// =====================================================================
// Qit3ati / AutoParts Cloud — Prisma Schema
// Mirrors 02_database_schema.sql; multi-tenant via tenant_id row scoping.
// =====================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Enums ----------
enum TenantPlan {
  basic
  pro
  business
  enterprise
}

enum TenantStatus {
  trial
  active
  suspended
  cancelled
}

enum StockStatus {
  available
  low
  out
  damaged
  returned
  reserved
}

enum PaymentType {
  cash
  credit
  card
  bank
  cheque
}

enum SaleStatus {
  draft
  completed
  cancelled
}

enum PartNumberType {
  oem
  alternative
  cross
}

enum TransferStatus {
  pending
  in_transit
  received
  cancelled
}

enum PriceTier {
  retail
  wholesale
  special
}

enum AccountType {
  asset
  liability
  equity
  revenue
  expense
}

enum WarrantyResolution {
  replace
  repair
  reject
}

enum TaskStatus {
  new
  in_progress
  done
}

enum DocumentType {
  govt
  license
  certificate
  contract
  customs
  invoice
  transfer
}

/// Types for the dedicated "OfficialPaper" feature (shop licenses, taxes, etc.)
enum OfficialPaperType {
  shop_license      // رخصة محل
  commercial_reg    // سجل تجاري
  profession_license // رخصة مهن
  tax               // ضريبة
  insurance         // تأمين
  lease             // عقد إيجار
  customs           // جمارك
  authorization     // تفويض
  other             // أخرى
}

/// Auto-computed by service from expiresAt + manual overrides like "in-progress".
enum OfficialPaperStatus {
  active            // سارية
  expiring_soon     // قاربت على الانتهاء (<=30 day)
  expired           // منتهية
  renewal_needed    // تحتاج تجديد (manual flag)
  in_progress       // قيد المعاملة (manual flag)
}

enum ChequeDirection {
  incoming          // شيك لنا (مستحق من عميل)
  outgoing          // شيك علينا (مستحق لمورد أو مصروف)
}

enum ChequeStatus {
  new               // جديد
  due_soon          // مستحق قريباً (<=7 days)
  due_today         // مستحق اليوم
  collected         // محصل (incoming → موصول إلى Receipt)
  paid              // مدفوع (outgoing → موصول إلى Payment)
  bounced           // مرتجع
  cancelled         // ملغي
}

/// JoFotara submission status — tracks each sales invoice's e-invoicing state.
enum JofotaraStatus {
  not_sent         // لم ترسل
  queued           // بانتظار الإرسال
  sent             // تم الإرسال (waiting for server response)
  accepted         // مقبولة من JoFotara
  rejected         // مرفوضة
  failed           // فشل الاتصال (يمكن إعادة الإرسال)
  needs_resubmit   // تحتاج إعادة إرسال (manual flag)
}

/// JoFotara environment — sandbox for testing, production for real submissions.
enum JofotaraEnvironment {
  sandbox
  production
}

/// Type of UBL document we're submitting.
enum JofotaraDocumentType {
  invoice          // فاتورة بيع عادية
  credit_note      // إشعار دائن (مرتجع/تخفيض)
  debit_note       // إشعار مدين (زيادة)
}

enum NotificationType {
  low_stock
  doc_expiry
  security
  daily_report
  debt
  other
}

enum NotificationChannel {
  in_app
  telegram
  sms
  whatsapp
}

enum StockMovementType {
  purchase
  sale
  return_in
  return_out
  transfer
  adjust
  damage
}

// ---------- (1) Tenancy core ----------

model Tenant {
  id           String       @id @default(uuid()) @db.Uuid
  name         String       @db.VarChar(150)
  slug         String       @unique @db.VarChar(80)
  plan         TenantPlan   @default(basic)
  status       TenantStatus @default(trial)
  trialEndsAt  DateTime?    @map("trial_ends_at") @db.Date
  maxBranches  Int          @default(1) @map("max_branches")
  maxUsers     Int          @default(2) @map("max_users")
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  settings     TenantSettings?
  branches     Branch[]
  warehouses   Warehouse[]
  users        User[]
  roles        Role[]
  categories   Category[]
  carMakes     CarMake[]
  carModels    CarModel[]
  parts        Part[]
  stocks       Stock[]
  suppliers    Supplier[]
  customers    Customer[]
  purchaseInvoices PurchaseInvoice[]
  salesInvoices    SalesInvoice[]
  posSessions      PosSession[]
  quotations       Quotation[]
  accounts         ChartAccount[]
  journalEntries   JournalEntry[]
  cashBoxes        CashBox[]
  banks            Bank[]
  receipts         Receipt[]
  payments         Payment[]
  expenseCategories ExpenseCategory[]
  expenses         Expense[]
  salesReturns     SalesReturn[]
  purchaseReturns  PurchaseReturn[]
  damagedItems     DamagedItem[]
  warranties       Warranty[]
  warrantyClaims   WarrantyClaim[]
  employees        Employee[]
  attendance       Attendance[]
  tasks            Task[]
  payrolls         Payroll[]
  documents        Document[]
  notifications    Notification[]
  telegramLinks    TelegramLink[]
  transfers        Transfer[]
  auditLogs        AuditLog[]
  partNumbers      PartNumber[]
  partCompats      PartCompatibility[]
  partImages       PartImage[]
  stockMovements   StockMovement[]
  stockCounts      StockCount[]
  officialPapers   OfficialPaper[]
  cheques          Cheque[]
  jofotaraConfig   JofotaraConfig?
  jofotaraSubmissions JofotaraSubmission[]
  fifoLayers       FifoLayer[]
  fifoConsumptions FifoConsumption[]
  vehicles         Vehicle[]
  jobCards         JobCard[]
  jobCardParts     JobCardPart[]
  jobCardLabors    JobCardLabor[]

  @@map("tenants")
}

model TenantSettings {
  tenantId        String   @id @map("tenant_id") @db.Uuid
  legalName       String?  @map("legal_name") @db.VarChar(200)
  taxNumber       String?  @map("tax_number") @db.VarChar(50)
  logoUrl         String?  @map("logo_url")
  colorPrimary    String   @default("#1E5F74") @map("color_primary") @db.VarChar(9)
  colorSecondary  String   @default("#FF7A00") @map("color_secondary") @db.VarChar(9)
  currency        String   @default("JOD") @db.VarChar(3)
  taxRate         Decimal  @default(16.00) @map("tax_rate") @db.Decimal(5, 2)
  language        String   @default("ar") @db.VarChar(5)
  invoiceHeader   String?  @map("invoice_header")
  invoiceFooter   String?  @map("invoice_footer")
  phone           String?  @db.VarChar(30)
  address         String?
  jofotaraEnabled Boolean  @default(false) @map("jofotara_enabled")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_settings")
}

model Branch {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String   @db.VarChar(120)
  code      String?  @db.VarChar(20)
  address   String?
  phone     String?  @db.VarChar(30)
  isMain    Boolean  @default(false) @map("is_main")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  warehouses  Warehouse[]
  stocks      Stock[]
  userBranches UserBranch[]
  purchaseInvoices PurchaseInvoice[]
  salesInvoices    SalesInvoice[]
  posSessions      PosSession[]
  quotations       Quotation[]
  journalEntries   JournalEntry[]
  cashBoxes        CashBox[]
  receipts         Receipt[]
  payments         Payment[]
  expenses         Expense[]
  salesReturns     SalesReturn[]
  purchaseReturns  PurchaseReturn[]
  damagedItems     DamagedItem[]
  employees        Employee[]
  tasks            Task[]
  transfersFrom    Transfer[] @relation("TransferFromBranch")
  transfersTo      Transfer[] @relation("TransferToBranch")
  stockMovements   StockMovement[]
  stockCounts      StockCount[]
  officialPapers   OfficialPaper[]
  cheques          Cheque[]
  jobCards         JobCard[]

  fifoLayers FifoLayer[]
  @@index([tenantId])
  @@map("branches")
}

model Warehouse {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  branchId  String   @map("branch_id") @db.Uuid
  name      String   @db.VarChar(120)
  isMain    Boolean  @default(false) @map("is_main")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  branch    Branch   @relation(fields: [branchId], references: [id])
  stocks    Stock[]

  @@index([tenantId, branchId])
  @@map("warehouses")
}

model Role {
  id       String   @id @default(uuid()) @db.Uuid
  tenantId String?  @map("tenant_id") @db.Uuid
  name     String   @db.VarChar(60)
  labelAr  String?  @map("label_ar") @db.VarChar(80)
  isSystem Boolean  @default(false) @map("is_system")

  tenant     Tenant?           @relation(fields: [tenantId], references: [id])
  users      User[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id      String  @id @default(uuid()) @db.Uuid
  code    String  @unique @db.VarChar(80)
  module  String? @db.VarChar(40)
  labelAr String? @map("label_ar") @db.VarChar(120)

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model User {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String?   @map("tenant_id") @db.Uuid
  roleId        String?   @map("role_id") @db.Uuid
  fullName      String    @map("full_name") @db.VarChar(150)
  email         String?   @db.VarChar(150)
  phone         String?   @db.VarChar(30)
  passwordHash  String    @map("password_hash")
  isSuperAdmin  Boolean   @default(false) @map("is_super_admin")
  isActive      Boolean   @default(true) @map("is_active")
  lastLoginAt   DateTime? @map("last_login_at") @db.Timestamptz
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz

  tenant         Tenant?       @relation(fields: [tenantId], references: [id])
  role           Role?         @relation(fields: [roleId], references: [id])
  userBranches   UserBranch[]
  auditLogs      AuditLog[]
  posSessions    PosSession[]
  salesInvoices  SalesInvoice[] @relation("SoldBy")
  purchaseInvoices PurchaseInvoice[] @relation("PurchaseCreatedBy")
  expensesCreated  Expense[] @relation("ExpenseCreatedBy")
  receiptsCreated  Receipt[] @relation("ReceiptCreatedBy")
  paymentsCreated  Payment[] @relation("PaymentCreatedBy")
  salesReturnsCreated  SalesReturn[] @relation("SalesReturnCreatedBy")
  purchaseReturnsCreated PurchaseReturn[] @relation("PurchaseReturnCreatedBy")
  damagedItemsCreated  DamagedItem[] @relation("DamagedItemCreatedBy")
  warrantyClaimsCreated WarrantyClaim[] @relation("WarrantyClaimCreatedBy")
  partsCreated      Part[] @relation("PartCreatedBy")
  stockMovements    StockMovement[]
  stockCounts       StockCount[]
  tasksCreated      Task[] @relation("TaskCreatedBy")
  documentsUploaded Document[]
  notifications     Notification[]
  telegramLinks     TelegramLink[]
  journalEntries    JournalEntry[]
  transfersCreated  Transfer[] @relation("TransferCreatedBy")
  transfersReceived Transfer[] @relation("TransferReceivedBy")
  officialPapersCreated OfficialPaper[]      @relation("OfficialPaperCreatedBy")
  officialPaperLogs     OfficialPaperLog[]
  chequesCreated        Cheque[]             @relation("ChequeCreatedBy")
  chequeStatusLogs      ChequeStatusLog[]
  jofotaraSubmissions   JofotaraSubmission[]
  jobCardsOpened        JobCard[]            @relation("JobCardOpenedBy")
  jobCardsAssigned      JobCard[]            @relation("JobCardMechanic")
  jobCardLaborsPerformed JobCardLabor[]      @relation("JobCardLaborPerformer")
  employee          Employee?

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

model UserBranch {
  userId   String @map("user_id") @db.Uuid
  branchId String @map("branch_id") @db.Uuid

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@id([userId, branchId])
  @@map("user_branches")
}

model AuditLog {
  id        BigInt   @id @default(autoincrement())
  tenantId  String   @map("tenant_id") @db.Uuid
  branchId  String?  @map("branch_id") @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  action    String?  @db.VarChar(40)
  entity    String?  @db.VarChar(60)
  entityId  String?  @map("entity_id") @db.Uuid
  oldValue  Json?    @map("old_value")
  newValue  Json?    @map("new_value")
  ipAddress String?  @map("ip_address") @db.Inet
  device    String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User?  @relation(fields: [userId], references: [id])

  @@index([tenantId, createdAt])
  @@map("audit_logs")
}

// ---------- (2) Catalog & Inventory ----------

model Category {
  id       String  @id @default(uuid()) @db.Uuid
  tenantId String  @map("tenant_id") @db.Uuid
  parentId String? @map("parent_id") @db.Uuid
  name     String  @db.VarChar(120)
  nameEn   String? @map("name_en") @db.VarChar(120)

  tenant   Tenant     @relation(fields: [tenantId], references: [id])
  parent   Category?  @relation("CategoryParent", fields: [parentId], references: [id])
  children Category[] @relation("CategoryParent")
  parts    Part[]

  @@map("categories")
}

model CarMake {
  id       String  @id @default(uuid()) @db.Uuid
  tenantId String? @map("tenant_id") @db.Uuid
  name     String  @db.VarChar(80)

  tenant Tenant?    @relation(fields: [tenantId], references: [id])
  models CarModel[]
  partCompatibilities PartCompatibility[]

  @@map("car_makes")
}

model CarModel {
  id       String  @id @default(uuid()) @db.Uuid
  tenantId String? @map("tenant_id") @db.Uuid
  makeId   String? @map("make_id") @db.Uuid
  name     String  @db.VarChar(80)
  yearFrom Int?    @map("year_from")
  yearTo   Int?    @map("year_to")

  tenant Tenant?  @relation(fields: [tenantId], references: [id])
  make   CarMake? @relation(fields: [makeId], references: [id])
  partCompatibilities PartCompatibility[]

  @@map("car_models")
}

model Part {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  sku            String   @db.VarChar(60)
  name           String   @db.VarChar(200)
  nameEn         String?  @map("name_en") @db.VarChar(200)
  categoryId     String?  @map("category_id") @db.Uuid
  partNumber     String?  @map("part_number") @db.VarChar(80)
  oemNumber      String?  @map("oem_number") @db.VarChar(80)
  barcode        String?  @db.VarChar(80)
  manufacturer   String?  @db.VarChar(120)
  countryOrigin  String?  @map("country_origin") @db.VarChar(80)
  unit           String   @default("حبة") @db.VarChar(20)
  costPrice      Decimal  @default(0) @map("cost_price") @db.Decimal(12, 3)
  avgCost        Decimal  @default(0) @map("avg_cost") @db.Decimal(12, 3)
  retailPrice    Decimal  @default(0) @map("retail_price") @db.Decimal(12, 3)
  wholesalePrice Decimal  @default(0) @map("wholesale_price") @db.Decimal(12, 3)
  minStock       Decimal  @default(0) @map("min_stock") @db.Decimal(12, 2)
  maxStock       Decimal? @map("max_stock") @db.Decimal(12, 2)
  reorderPoint   Decimal? @map("reorder_point") @db.Decimal(12, 2)
  warrantyMonths Int      @default(0) @map("warranty_months")
  taxRate        Decimal  @default(16.00) @map("tax_rate") @db.Decimal(5, 2)
  isActive       Boolean  @default(true) @map("is_active")
  createdBy      String?  @map("created_by") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  category  Category? @relation(fields: [categoryId], references: [id])
  creator   User?     @relation("PartCreatedBy", fields: [createdBy], references: [id])
  numbers   PartNumber[]
  compats   PartCompatibility[]
  images    PartImage[]
  stocks    Stock[]
  movements StockMovement[]
  substitutesA  PartSubstitute[] @relation("PartA")
  substitutesB  PartSubstitute[] @relation("PartB")
  customerSpecialPrices CustomerSpecialPrice[]
  priceTiers   PartPriceTier[]
  purchaseItems PurchaseItem[]
  salesItems    SalesItem[]
  countItems    StockCountItem[]
  transferItems TransferItem[]
  salesReturnItems   SalesReturnItem[]
  purchaseReturnItems PurchaseReturnItem[]
  damagedItems  DamagedItem[]
  warranties    Warranty[]
  jobCardParts  JobCardPart[]

  fifoLayers FifoLayer[]
  @@unique([tenantId, sku])
  @@index([tenantId])
  @@index([tenantId, partNumber, oemNumber, barcode])
  @@map("parts")
}

model PartNumber {
  id         String         @id @default(uuid()) @db.Uuid
  tenantId   String         @map("tenant_id") @db.Uuid
  partId     String         @map("part_id") @db.Uuid
  number     String         @db.VarChar(80)
  numberType PartNumberType @default(alternative) @map("number_type")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  part   Part   @relation(fields: [partId], references: [id], onDelete: Cascade)

  @@index([tenantId, number])
  @@map("part_numbers")
}

model PartCompatibility {
  id        String  @id @default(uuid()) @db.Uuid
  tenantId  String  @map("tenant_id") @db.Uuid
  partId    String  @map("part_id") @db.Uuid
  makeId    String? @map("make_id") @db.Uuid
  modelId   String? @map("model_id") @db.Uuid
  yearFrom  Int?    @map("year_from")
  yearTo    Int?    @map("year_to")
  engine    String? @db.VarChar(60)

  tenant Tenant   @relation(fields: [tenantId], references: [id])
  part   Part     @relation(fields: [partId], references: [id], onDelete: Cascade)
  make   CarMake? @relation(fields: [makeId], references: [id])
  model  CarModel? @relation(fields: [modelId], references: [id])

  @@map("part_compatibility")
}

model PartSubstitute {
  partId       String @map("part_id") @db.Uuid
  substituteId String @map("substitute_id") @db.Uuid

  part       Part @relation("PartA", fields: [partId], references: [id], onDelete: Cascade)
  substitute Part @relation("PartB", fields: [substituteId], references: [id], onDelete: Cascade)

  @@id([partId, substituteId])
  @@map("part_substitutes")
}

model PartImage {
  id        String  @id @default(uuid()) @db.Uuid
  tenantId  String  @map("tenant_id") @db.Uuid
  partId    String  @map("part_id") @db.Uuid
  url       String
  isPrimary Boolean @default(false) @map("is_primary")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  part   Part   @relation(fields: [partId], references: [id], onDelete: Cascade)

  @@map("part_images")
}

model Stock {
  id         String      @id @default(uuid()) @db.Uuid
  tenantId   String      @map("tenant_id") @db.Uuid
  branchId   String      @map("branch_id") @db.Uuid
  warehouseId String?    @map("warehouse_id") @db.Uuid
  partId     String      @map("part_id") @db.Uuid
  quantity   Decimal     @default(0) @db.Decimal(12, 2)
  reserved   Decimal     @default(0) @db.Decimal(12, 2)
  location   String?     @db.VarChar(60)
  status     StockStatus @default(available)

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  branch    Branch     @relation(fields: [branchId], references: [id])
  warehouse Warehouse? @relation(fields: [warehouseId], references: [id])
  part      Part       @relation(fields: [partId], references: [id])

  @@unique([tenantId, warehouseId, partId])
  @@index([tenantId, branchId, partId])
  @@map("stock")
}

model StockMovement {
  id         BigInt            @id @default(autoincrement())
  tenantId   String            @map("tenant_id") @db.Uuid
  branchId   String            @map("branch_id") @db.Uuid
  partId     String            @map("part_id") @db.Uuid
  type       StockMovementType
  qtyChange  Decimal           @map("qty_change") @db.Decimal(12, 2)
  refTable   String?           @map("ref_table") @db.VarChar(40)
  refId      String?           @map("ref_id") @db.Uuid
  unitCost   Decimal?          @map("unit_cost") @db.Decimal(12, 3)
  userId     String?           @map("user_id") @db.Uuid
  createdAt  DateTime          @default(now()) @map("created_at") @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])
  branch Branch @relation(fields: [branchId], references: [id])
  part   Part   @relation(fields: [partId], references: [id])
  user   User?  @relation(fields: [userId], references: [id])

  @@index([tenantId, partId, createdAt])
  @@map("stock_movements")
}

model StockCount {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  branchId  String   @map("branch_id") @db.Uuid
  status    String   @default("draft") @db.VarChar(20)
  countedBy String?  @map("counted_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenant Tenant            @relation(fields: [tenantId], references: [id])
  branch Branch            @relation(fields: [branchId], references: [id])
  user   User?             @relation(fields: [countedBy], references: [id])
  items  StockCountItem[]

  @@map("stock_counts")
}

model StockCountItem {
  countId    String  @map("count_id") @db.Uuid
  partId     String  @map("part_id") @db.Uuid
  systemQty  Decimal? @map("system_qty") @db.Decimal(12, 2)
  countedQty Decimal? @map("counted_qty") @db.Decimal(12, 2)

  count StockCount @relation(fields: [countId], references: [id], onDelete: Cascade)
  part  Part       @relation(fields: [partId], references: [id])

  @@id([countId, partId])
  @@map("stock_count_items")
}

model Transfer {
  id         String         @id @default(uuid()) @db.Uuid
  tenantId   String         @map("tenant_id") @db.Uuid
  fromBranch String?        @map("from_branch") @db.Uuid
  toBranch   String?        @map("to_branch") @db.Uuid
  status     TransferStatus @default(pending)
  createdBy  String?        @map("created_by") @db.Uuid
  receivedBy String?        @map("received_by") @db.Uuid
  createdAt  DateTime       @default(now()) @map("created_at") @db.Timestamptz

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  from     Branch?  @relation("TransferFromBranch", fields: [fromBranch], references: [id])
  to       Branch?  @relation("TransferToBranch", fields: [toBranch], references: [id])
  creator  User?    @relation("TransferCreatedBy", fields: [createdBy], references: [id])
  receiver User?    @relation("TransferReceivedBy", fields: [receivedBy], references: [id])
  items    TransferItem[]

  @@map("transfers")
}

model TransferItem {
  transferId  String  @map("transfer_id") @db.Uuid
  partId      String  @map("part_id") @db.Uuid
  qtySent     Decimal? @map("qty_sent") @db.Decimal(12, 2)
  qtyReceived Decimal? @map("qty_received") @db.Decimal(12, 2)

  transfer Transfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  part     Part     @relation(fields: [partId], references: [id])

  @@id([transferId, partId])
  @@map("transfer_items")
}

// ---------- (3) Suppliers, Customers, Purchases, Sales ----------

model Supplier {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String   @db.VarChar(150)
  phone     String?  @db.VarChar(30)
  email     String?  @db.VarChar(120)
  taxNumber String?  @map("tax_number") @db.VarChar(50)
  address   String?
  balance   Decimal  @default(0) @db.Decimal(14, 3)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  tenant            Tenant            @relation(fields: [tenantId], references: [id])
  purchaseInvoices  PurchaseInvoice[]
  payments          Payment[]
  purchaseReturns   PurchaseReturn[]
  cheques           Cheque[]

  @@index([tenantId])
  @@map("suppliers")
}

model Customer {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  name        String    @db.VarChar(150)
  phone       String?   @db.VarChar(30)
  email       String?   @db.VarChar(120)
  taxNumber   String?   @map("tax_number") @db.VarChar(50)
  address     String?
  priceTier   PriceTier @default(retail) @map("price_tier")
  creditLimit Decimal   @default(0) @map("credit_limit") @db.Decimal(14, 3)
  balance     Decimal   @default(0) @db.Decimal(14, 3)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz

  tenant             Tenant   @relation(fields: [tenantId], references: [id])
  salesInvoices      SalesInvoice[]
  receipts           Receipt[]
  quotations         Quotation[]
  specialPrices      CustomerSpecialPrice[]
  warranties         Warranty[]
  cheques            Cheque[]
  vehicles           Vehicle[]
  jobCards           JobCard[]

  @@index([tenantId])
  @@map("customers")
}

model CustomerSpecialPrice {
  customerId String  @map("customer_id") @db.Uuid
  partId     String  @map("part_id") @db.Uuid
  price      Decimal @db.Decimal(12, 3)

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  part     Part     @relation(fields: [partId], references: [id], onDelete: Cascade)

  @@id([customerId, partId])
  @@map("customer_special_prices")
}

model PartPriceTier {
  id       String   @id @default(uuid()) @db.Uuid
  tenantId String   @map("tenant_id") @db.Uuid
  partId   String?  @map("part_id") @db.Uuid
  minQty   Decimal? @map("min_qty") @db.Decimal(12, 2)
  price    Decimal? @db.Decimal(12, 3)

  part Part? @relation(fields: [partId], references: [id], onDelete: Cascade)

  @@map("price_tiers")
}

model PurchaseInvoice {
  id            String       @id @default(uuid()) @db.Uuid
  tenantId      String       @map("tenant_id") @db.Uuid
  branchId      String       @map("branch_id") @db.Uuid
  supplierId    String?      @map("supplier_id") @db.Uuid
  invoiceNo     String?      @map("invoice_no") @db.VarChar(40)
  supplierRef   String?      @map("supplier_ref") @db.VarChar(60)
  invoiceDate   DateTime     @default(now()) @map("invoice_date") @db.Date
  subtotal      Decimal      @default(0) @db.Decimal(14, 3)
  tax           Decimal      @default(0) @db.Decimal(14, 3)
  total         Decimal      @default(0) @db.Decimal(14, 3)
  paid          Decimal      @default(0) @db.Decimal(14, 3)
  paymentType   PaymentType  @default(cash) @map("payment_type")
  status        String       @default("received") @db.VarChar(20)
  attachmentUrl String?      @map("attachment_url")
  createdBy     String?      @map("created_by") @db.Uuid
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz
  deletedAt     DateTime?    @map("deleted_at") @db.Timestamptz

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  branch   Branch    @relation(fields: [branchId], references: [id])
  supplier Supplier? @relation(fields: [supplierId], references: [id])
  creator  User?     @relation("PurchaseCreatedBy", fields: [createdBy], references: [id])
  items    PurchaseItem[]
  returns  PurchaseReturn[]

  @@index([tenantId, branchId, invoiceDate])
  @@map("purchase_invoices")
}

model PurchaseItem {
  id        String  @id @default(uuid()) @db.Uuid
  invoiceId String  @map("invoice_id") @db.Uuid
  partId    String? @map("part_id") @db.Uuid
  qty       Decimal? @db.Decimal(12, 2)
  unitCost  Decimal? @map("unit_cost") @db.Decimal(12, 3)
  lineTotal Decimal? @map("line_total") @db.Decimal(14, 3)

  invoice PurchaseInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  part    Part?           @relation(fields: [partId], references: [id])

  fifoLayer FifoLayer?
  @@map("purchase_items")
}

model PosSession {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  branchId    String    @map("branch_id") @db.Uuid
  userId      String?   @map("user_id") @db.Uuid
  openingCash Decimal   @default(0) @map("opening_cash") @db.Decimal(14, 3)
  closingCash Decimal?  @map("closing_cash") @db.Decimal(14, 3)
  openedAt    DateTime  @default(now()) @map("opened_at") @db.Timestamptz
  closedAt    DateTime? @map("closed_at") @db.Timestamptz
  status      String    @default("open") @db.VarChar(20)

  tenant Tenant @relation(fields: [tenantId], references: [id])
  branch Branch @relation(fields: [branchId], references: [id])
  user   User?  @relation(fields: [userId], references: [id])
  salesInvoices SalesInvoice[]

  @@map("pos_sessions")
}

model SalesInvoice {
  id            String       @id @default(uuid()) @db.Uuid
  tenantId      String       @map("tenant_id") @db.Uuid
  branchId      String       @map("branch_id") @db.Uuid
  posSessionId  String?      @map("pos_session_id") @db.Uuid
  customerId    String?      @map("customer_id") @db.Uuid
  invoiceNo     String?      @map("invoice_no") @db.VarChar(40)
  invoiceDate   DateTime     @default(now()) @map("invoice_date") @db.Date
  subtotal      Decimal      @default(0) @db.Decimal(14, 3)
  discount      Decimal      @default(0) @db.Decimal(14, 3)
  tax           Decimal      @default(0) @db.Decimal(14, 3)
  total         Decimal      @default(0) @db.Decimal(14, 3)
  paid          Decimal      @default(0) @db.Decimal(14, 3)
  paymentType   PaymentType  @default(cash) @map("payment_type")
  status        SaleStatus   @default(completed)
  // ---- JoFotara fields ----
  jofotaraStatus      JofotaraStatus @default(not_sent) @map("jofotara_status")
  jofotaraUuid        String?        @map("jofotara_uuid") @db.VarChar(80)
  jofotaraQr          String?        @map("jofotara_qr")
  jofotaraError       String?        @map("jofotara_error")
  jofotaraSubmittedAt DateTime?      @map("jofotara_submitted_at") @db.Timestamptz
  jofotaraXml         String?        @map("jofotara_xml")  // last sent UBL XML (for debug/replay)
  /**
   * If this invoice was auto-generated from a workshop job card
   * (via the "Complete + convert to invoice" flow), this points
   * back to the source card for full traceability. Nullable so
   * POS/normal sales continue to work unchanged.
   */
  jobCardId     String?      @unique @map("job_card_id") @db.Uuid
  soldBy        String?      @map("sold_by") @db.Uuid
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz
  deletedAt     DateTime?    @map("deleted_at") @db.Timestamptz

  tenant     Tenant       @relation(fields: [tenantId], references: [id])
  branch     Branch       @relation(fields: [branchId], references: [id])
  posSession PosSession?  @relation(fields: [posSessionId], references: [id])
  customer   Customer?    @relation(fields: [customerId], references: [id])
  seller     User?        @relation("SoldBy", fields: [soldBy], references: [id])
  items      SalesItem[]
  returns    SalesReturn[]
  jofotaraSubmissions JofotaraSubmission[]
  jobCard    JobCard?     @relation(fields: [jobCardId], references: [id])

  @@index([tenantId, branchId, invoiceDate])
  @@index([tenantId, jofotaraStatus])
  @@map("sales_invoices")
}

model SalesItem {
  id            String   @id @default(uuid()) @db.Uuid
  invoiceId     String   @map("invoice_id") @db.Uuid
  partId        String?  @map("part_id") @db.Uuid
  qty           Decimal? @db.Decimal(12, 2)
  unitPrice     Decimal? @map("unit_price") @db.Decimal(12, 3)
  unitCost      Decimal? @map("unit_cost") @db.Decimal(12, 3)
  discount      Decimal  @default(0) @db.Decimal(12, 3)
  lineTotal     Decimal? @map("line_total") @db.Decimal(14, 3)
  warrantyUntil DateTime? @map("warranty_until") @db.Date

  invoice    SalesInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  part       Part?        @relation(fields: [partId], references: [id])
  warranties Warranty[]

  fifoConsumptions FifoConsumption[]
  @@map("sales_items")
}

model Quotation {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  branchId   String?  @map("branch_id") @db.Uuid
  customerId String?  @map("customer_id") @db.Uuid
  total      Decimal? @db.Decimal(14, 3)
  validUntil DateTime? @map("valid_until") @db.Date
  status     String   @default("open") @db.VarChar(20)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  branch   Branch?   @relation(fields: [branchId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])

  @@map("quotations")
}

// ---------- (4) Accounting ----------

model ChartAccount {
  id       String      @id @default(uuid()) @db.Uuid
  tenantId String      @map("tenant_id") @db.Uuid
  code     String?     @db.VarChar(20)
  name     String      @db.VarChar(150)
  type     AccountType
  parentId String?     @map("parent_id") @db.Uuid

  tenant   Tenant         @relation(fields: [tenantId], references: [id])
  parent   ChartAccount?  @relation("ChartParent", fields: [parentId], references: [id])
  children ChartAccount[] @relation("ChartParent")
  lines    JournalLine[]

  @@map("chart_of_accounts")
}

model JournalEntry {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  branchId    String?  @map("branch_id") @db.Uuid
  entryDate   DateTime @default(now()) @map("entry_date") @db.Date
  description String?
  refTable    String?  @map("ref_table") @db.VarChar(40)
  refId       String?  @map("ref_id") @db.Uuid
  isAuto      Boolean  @default(true) @map("is_auto")
  createdBy   String?  @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenant  Tenant         @relation(fields: [tenantId], references: [id])
  branch  Branch?        @relation(fields: [branchId], references: [id])
  creator User?          @relation(fields: [createdBy], references: [id])
  lines   JournalLine[]

  @@map("journal_entries")
}

model JournalLine {
  id        String   @id @default(uuid()) @db.Uuid
  entryId   String   @map("entry_id") @db.Uuid
  accountId String   @map("account_id") @db.Uuid
  debit     Decimal  @default(0) @db.Decimal(14, 3)
  credit    Decimal  @default(0) @db.Decimal(14, 3)

  entry   JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  account ChartAccount @relation(fields: [accountId], references: [id])

  @@map("journal_lines")
}

model CashBox {
  id       String  @id @default(uuid()) @db.Uuid
  tenantId String  @map("tenant_id") @db.Uuid
  branchId String? @map("branch_id") @db.Uuid
  name     String? @db.VarChar(80)
  balance  Decimal @default(0) @db.Decimal(14, 3)

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  branch Branch? @relation(fields: [branchId], references: [id])

  @@map("cash_boxes")
}

model Bank {
  id        String  @id @default(uuid()) @db.Uuid
  tenantId  String  @map("tenant_id") @db.Uuid
  name      String? @db.VarChar(120)
  accountNo String? @map("account_no") @db.VarChar(60)
  balance   Decimal @default(0) @db.Decimal(14, 3)

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  cheques Cheque[]

  @@map("banks")
}

model Receipt {
  id          String      @id @default(uuid()) @db.Uuid
  tenantId    String      @map("tenant_id") @db.Uuid
  branchId    String?     @map("branch_id") @db.Uuid
  customerId  String?     @map("customer_id") @db.Uuid
  amount      Decimal     @db.Decimal(14, 3)
  method      PaymentType @default(cash)
  chequeNo    String?     @map("cheque_no") @db.VarChar(40)
  chequeDate  DateTime?   @map("cheque_date") @db.Date
  receiptDate DateTime    @default(now()) @map("receipt_date") @db.Date
  createdBy   String?     @map("created_by") @db.Uuid
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  branch   Branch?   @relation(fields: [branchId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])
  creator  User?     @relation("ReceiptCreatedBy", fields: [createdBy], references: [id])
  cheque   Cheque?

  @@map("receipts")
}

model Payment {
  id          String      @id @default(uuid()) @db.Uuid
  tenantId    String      @map("tenant_id") @db.Uuid
  branchId    String?     @map("branch_id") @db.Uuid
  supplierId  String?     @map("supplier_id") @db.Uuid
  amount      Decimal     @db.Decimal(14, 3)
  method      PaymentType @default(cash)
  paymentDate DateTime    @default(now()) @map("payment_date") @db.Date
  createdBy   String?     @map("created_by") @db.Uuid
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  branch   Branch?   @relation(fields: [branchId], references: [id])
  supplier Supplier? @relation(fields: [supplierId], references: [id])
  creator  User?     @relation("PaymentCreatedBy", fields: [createdBy], references: [id])
  cheque   Cheque?

  @@map("payments")
}

model ExpenseCategory {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid
  name     String @db.VarChar(100)

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  expenses Expense[]

  @@map("expense_categories")
}

model Expense {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  branchId      String?  @map("branch_id") @db.Uuid
  categoryId    String?  @map("category_id") @db.Uuid
  amount        Decimal  @db.Decimal(14, 3)
  description   String?
  attachmentUrl String?  @map("attachment_url")
  expenseDate   DateTime @default(now()) @map("expense_date") @db.Date
  createdBy     String?  @map("created_by") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenant   Tenant            @relation(fields: [tenantId], references: [id])
  branch   Branch?           @relation(fields: [branchId], references: [id])
  category ExpenseCategory?  @relation(fields: [categoryId], references: [id])
  creator  User?             @relation("ExpenseCreatedBy", fields: [createdBy], references: [id])

  @@map("expenses")
}

// ---------- (5) Returns / Damaged / Warranties ----------

model SalesReturn {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  branchId     String?  @map("branch_id") @db.Uuid
  invoiceId    String?  @map("invoice_id") @db.Uuid
  reason       String?
  refundMethod String?  @map("refund_method") @db.VarChar(20)
  total        Decimal? @db.Decimal(14, 3)
  createdBy    String?  @map("created_by") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenant  Tenant        @relation(fields: [tenantId], references: [id])
  branch  Branch?       @relation(fields: [branchId], references: [id])
  invoice SalesInvoice? @relation(fields: [invoiceId], references: [id])
  creator User?         @relation("SalesReturnCreatedBy", fields: [createdBy], references: [id])
  items   SalesReturnItem[]

  @@map("sales_returns")
}

model SalesReturnItem {
  returnId    String  @map("return_id") @db.Uuid
  partId      String  @map("part_id") @db.Uuid
  qty         Decimal? @db.Decimal(12, 2)
  unitPrice   Decimal? @map("unit_price") @db.Decimal(12, 3)
  condition   String   @default("good") @db.VarChar(20)
  backToStock Boolean  @default(true) @map("back_to_stock")

  salesReturn SalesReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)
  part        Part        @relation(fields: [partId], references: [id])

  @@id([returnId, partId])
  @@map("sales_return_items")
}

model PurchaseReturn {
  id                String   @id @default(uuid()) @db.Uuid
  tenantId          String   @map("tenant_id") @db.Uuid
  branchId          String?  @map("branch_id") @db.Uuid
  supplierId        String?  @map("supplier_id") @db.Uuid
  purchaseInvoiceId String?  @map("purchase_invoice_id") @db.Uuid
  reason            String?
  total             Decimal? @db.Decimal(14, 3)
  createdBy         String?  @map("created_by") @db.Uuid
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenant   Tenant           @relation(fields: [tenantId], references: [id])
  branch   Branch?          @relation(fields: [branchId], references: [id])
  supplier Supplier?        @relation(fields: [supplierId], references: [id])
  invoice  PurchaseInvoice? @relation(fields: [purchaseInvoiceId], references: [id])
  creator  User?            @relation("PurchaseReturnCreatedBy", fields: [createdBy], references: [id])
  items    PurchaseReturnItem[]

  @@map("purchase_returns")
}

model PurchaseReturnItem {
  returnId String  @map("return_id") @db.Uuid
  partId   String  @map("part_id") @db.Uuid
  qty      Decimal? @db.Decimal(12, 2)
  unitCost Decimal? @map("unit_cost") @db.Decimal(12, 3)

  purchaseReturn PurchaseReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)
  part           Part           @relation(fields: [partId], references: [id])

  @@id([returnId, partId])
  @@map("purchase_return_items")
}

model DamagedItem {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  branchId      String?  @map("branch_id") @db.Uuid
  partId        String?  @map("part_id") @db.Uuid
  qty           Decimal? @db.Decimal(12, 2)
  reason        String?
  attachmentUrl String?  @map("attachment_url")
  createdBy     String?  @map("created_by") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  branch  Branch? @relation(fields: [branchId], references: [id])
  part    Part?   @relation(fields: [partId], references: [id])
  creator User?   @relation("DamagedItemCreatedBy", fields: [createdBy], references: [id])

  @@map("damaged_items")
}

model Warranty {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  salesItemId String?  @map("sales_item_id") @db.Uuid
  partId      String?  @map("part_id") @db.Uuid
  customerId  String?  @map("customer_id") @db.Uuid
  startDate   DateTime? @map("start_date") @db.Date
  endDate     DateTime? @map("end_date") @db.Date
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  salesItem SalesItem? @relation(fields: [salesItemId], references: [id])
  part      Part?      @relation(fields: [partId], references: [id])
  customer  Customer?  @relation(fields: [customerId], references: [id])
  claims    WarrantyClaim[]

  @@map("warranties")
}

model WarrantyClaim {
  id          String              @id @default(uuid()) @db.Uuid
  tenantId    String              @map("tenant_id") @db.Uuid
  warrantyId  String?             @map("warranty_id") @db.Uuid
  claimDate   DateTime            @default(now()) @map("claim_date") @db.Date
  resolution  WarrantyResolution?
  notes       String?
  createdBy   String?             @map("created_by") @db.Uuid

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  warranty Warranty? @relation(fields: [warrantyId], references: [id])
  creator  User?     @relation("WarrantyClaimCreatedBy", fields: [createdBy], references: [id])

  @@map("warranty_claims")
}

// ---------- (6) HR ----------

model Employee {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  branchId       String?  @map("branch_id") @db.Uuid
  userId         String?  @unique @map("user_id") @db.Uuid
  fullName       String   @map("full_name") @db.VarChar(150)
  jobTitle       String?  @map("job_title") @db.VarChar(80)
  phone          String?  @db.VarChar(30)
  salary         Decimal  @default(0) @db.Decimal(12, 3)
  commissionRate Decimal  @default(0) @map("commission_rate") @db.Decimal(5, 2)
  hiredAt        DateTime? @map("hired_at") @db.Date
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz

  tenant     Tenant       @relation(fields: [tenantId], references: [id])
  branch     Branch?      @relation(fields: [branchId], references: [id])
  user       User?        @relation(fields: [userId], references: [id])
  attendance Attendance[]
  tasks      Task[]
  payrolls   Payroll[]

  @@map("employees")
}

model Attendance {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  employeeId String?   @map("employee_id") @db.Uuid
  checkIn    DateTime? @map("check_in") @db.Timestamptz
  checkOut   DateTime? @map("check_out") @db.Timestamptz
  workDate   DateTime  @default(now()) @map("work_date") @db.Date
  location   String?

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  employee Employee? @relation(fields: [employeeId], references: [id])

  @@map("attendance")
}

model Task {
  id          String     @id @default(uuid()) @db.Uuid
  tenantId    String     @map("tenant_id") @db.Uuid
  branchId    String?    @map("branch_id") @db.Uuid
  title       String     @db.VarChar(200)
  description String?
  assignedTo  String?    @map("assigned_to") @db.Uuid
  status      TaskStatus @default(new)
  dueDate     DateTime?  @map("due_date") @db.Date
  createdBy   String?    @map("created_by") @db.Uuid
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  branch   Branch?   @relation(fields: [branchId], references: [id])
  assignee Employee? @relation(fields: [assignedTo], references: [id])
  creator  User?     @relation("TaskCreatedBy", fields: [createdBy], references: [id])

  @@map("tasks")
}

model Payroll {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  employeeId String?  @map("employee_id") @db.Uuid
  period     String?  @db.VarChar(7)
  base       Decimal? @db.Decimal(12, 3)
  commission Decimal  @default(0) @db.Decimal(12, 3)
  deductions Decimal  @default(0) @db.Decimal(12, 3)
  net        Decimal? @db.Decimal(12, 3)
  paid       Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  employee Employee? @relation(fields: [employeeId], references: [id])

  @@map("payroll")
}

// ---------- (7) Documents + Notifications + Telegram ----------

model Document {
  id          String        @id @default(uuid()) @db.Uuid
  tenantId    String        @map("tenant_id") @db.Uuid
  title       String        @db.VarChar(200)
  docType     DocumentType? @map("doc_type")
  fileUrl     String        @map("file_url")
  issueDate   DateTime?     @map("issue_date") @db.Date
  expiryDate  DateTime?     @map("expiry_date") @db.Date
  linkedTable String?       @map("linked_table") @db.VarChar(40)
  linkedId    String?       @map("linked_id") @db.Uuid
  uploadedBy  String?       @map("uploaded_by") @db.Uuid
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz
  deletedAt   DateTime?     @map("deleted_at") @db.Timestamptz

  tenant   Tenant @relation(fields: [tenantId], references: [id])
  uploader User?  @relation(fields: [uploadedBy], references: [id])

  @@index([tenantId, expiryDate])
  @@map("documents")
}

model Notification {
  id        BigInt              @id @default(autoincrement())
  tenantId  String              @map("tenant_id") @db.Uuid
  userId    String?             @map("user_id") @db.Uuid
  type      NotificationType?
  title     String?             @db.VarChar(200)
  body      String?
  channel   NotificationChannel @default(in_app)
  isRead    Boolean             @default(false) @map("is_read")
  createdAt DateTime            @default(now()) @map("created_at") @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User?  @relation(fields: [userId], references: [id])

  @@map("notifications")
}

/// Atomic sequence counters per tenant — used for invoice numbers etc.
/// Prevents race conditions when multiple invoices are created concurrently.
model TenantCounter {
  tenantId   String   @map("tenant_id") @db.Uuid
  counterKey String   @map("counter_key") @db.VarChar(60)
  value      BigInt   @default(0)
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@id([tenantId, counterKey])
  @@map("tenant_counters")
}

/// ---------------------------------------------------------------------------
/// OFFICIAL PAPERS — shop licenses, taxes, leases, customs, etc.
/// Dedicated feature distinct from the generic Document table — fixed types,
/// issuer, branch ownership, computed status, change log, alert flags.
/// ---------------------------------------------------------------------------
model OfficialPaper {
  id               String              @id @default(uuid()) @db.Uuid
  tenantId         String              @map("tenant_id") @db.Uuid
  branchId         String?             @map("branch_id") @db.Uuid
  type             OfficialPaperType
  title            String              @db.VarChar(200)   // اسم/عنوان
  docNumber        String?             @map("doc_number") @db.VarChar(100)
  issuer           String?             @db.VarChar(200)   // الجهة المصدرة
  issuedAt         DateTime?           @map("issued_at") @db.Date
  expiresAt        DateTime?           @map("expires_at") @db.Date
  /// Optional manual override; otherwise the service computes from expiresAt.
  /// Use this for `renewal_needed` and `in_progress` which can't be derived.
  statusOverride   OfficialPaperStatus? @map("status_override")
  notes            String?
  fileUrl          String?             @map("file_url")
  /// last time we sent any alert to the owner (debounce: same paper, same day).
  lastAlertAt      DateTime?           @map("last_alert_at") @db.Timestamptz
  /// which alert thresholds already fired (CSV: "30,15,7" so we don't re-send)
  alertedDays      String?             @map("alerted_days") @db.VarChar(40)
  createdBy        String?             @map("created_by") @db.Uuid
  createdAt        DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt        DateTime?           @map("deleted_at") @db.Timestamptz

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  branch  Branch? @relation(fields: [branchId], references: [id])
  creator User?   @relation("OfficialPaperCreatedBy", fields: [createdBy], references: [id])
  logs    OfficialPaperLog[]

  @@index([tenantId, expiresAt])
  @@index([tenantId, type])
  @@index([tenantId, branchId])
  @@map("official_papers")
}

/// Append-only change log for an OfficialPaper (audit trail).
model OfficialPaperLog {
  id        BigInt   @id @default(autoincrement())
  paperId   String   @map("paper_id") @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  action    String   @db.VarChar(40) // created | updated | renewed | status_changed | file_replaced
  details   Json?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  paper OfficialPaper @relation(fields: [paperId], references: [id], onDelete: Cascade)
  user  User?         @relation(fields: [userId], references: [id])

  @@index([paperId, createdAt])
  @@map("official_paper_logs")
}

/// ---------------------------------------------------------------------------
/// CHEQUES — incoming (from customers, owed TO us) and outgoing (TO suppliers).
/// Lifecycle:
///   new → due_soon (auto, within 7d) → due_today (auto)
///        → collected (incoming, creates a Receipt)
///        OR paid (outgoing, creates a Payment)
///        OR bounced / cancelled
/// ---------------------------------------------------------------------------
model Cheque {
  id               String          @id @default(uuid()) @db.Uuid
  tenantId         String          @map("tenant_id") @db.Uuid
  branchId         String?         @map("branch_id") @db.Uuid
  direction        ChequeDirection
  chequeNo         String          @map("cheque_no") @db.VarChar(60)
  bankId           String?         @map("bank_id") @db.Uuid
  bankName         String?         @map("bank_name") @db.VarChar(150) // free text fallback
  /// Owner of the cheque (the drawer for incoming, the beneficiary for outgoing).
  /// Free text because not every payer/payee is in the customer/supplier list.
  partyName        String?         @map("party_name") @db.VarChar(200)
  customerId       String?         @map("customer_id") @db.Uuid
  supplierId       String?         @map("supplier_id") @db.Uuid
  amount           Decimal         @db.Decimal(14, 3)
  dueDate          DateTime        @map("due_date") @db.Date
  /// Manual override; service computes new/due_soon/due_today otherwise.
  status           ChequeStatus    @default(new)
  notes            String?
  fileUrl          String?         @map("file_url")
  /// Once settled, link to the auto-generated Receipt/Payment for traceability.
  receiptId        String?         @unique @map("receipt_id") @db.Uuid
  paymentId        String?         @unique @map("payment_id") @db.Uuid
  /// Reason set when status moves to bounced/cancelled.
  bounceReason     String?         @map("bounce_reason") @db.VarChar(300)
  bouncedAt        DateTime?       @map("bounced_at") @db.Timestamptz
  settledAt        DateTime?       @map("settled_at") @db.Timestamptz
  /// Alert tracking — CSV of fired thresholds ("7,3,0").
  alertedDays      String?         @map("alerted_days") @db.VarChar(40)
  createdBy        String?         @map("created_by") @db.Uuid
  createdAt        DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt        DateTime?       @map("deleted_at") @db.Timestamptz

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  branch   Branch?   @relation(fields: [branchId], references: [id])
  bank     Bank?     @relation(fields: [bankId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])
  supplier Supplier? @relation(fields: [supplierId], references: [id])
  creator  User?     @relation("ChequeCreatedBy", fields: [createdBy], references: [id])
  receipt  Receipt?  @relation(fields: [receiptId], references: [id])
  payment  Payment?  @relation(fields: [paymentId], references: [id])
  logs     ChequeStatusLog[]

  @@index([tenantId, direction])
  @@index([tenantId, status])
  @@index([tenantId, dueDate])
  @@map("cheques")
}

/// Append-only log of cheque status transitions (who/when/why).
model ChequeStatusLog {
  id        BigInt        @id @default(autoincrement())
  chequeId  String        @map("cheque_id") @db.Uuid
  userId    String?       @map("user_id") @db.Uuid
  fromStatus ChequeStatus? @map("from_status")
  toStatus   ChequeStatus  @map("to_status")
  note      String?
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz

  cheque Cheque @relation(fields: [chequeId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id])

  @@index([chequeId, createdAt])
  @@map("cheque_status_logs")
}

/// ---------------------------------------------------------------------------
/// JOFOTARA — Jordan's national e-invoicing system (ISTD)
/// One config row per tenant. Secret key is stored ENCRYPTED at rest using
/// AES-256-GCM with a master key from env `JOFOTARA_MASTER_KEY` (set on Render).
/// The plain secret never leaves the server — APIs return masked strings only.
/// ---------------------------------------------------------------------------
model JofotaraConfig {
  tenantId            String              @id @map("tenant_id") @db.Uuid
  /// API client identifier issued by JoFotara onboarding.
  clientId            String?             @map("client_id") @db.VarChar(120)
  /// ENCRYPTED secret — never expose via API responses except a 4-char preview.
  /// Format: `<iv-hex>:<authTag-hex>:<ciphertext-hex>`.
  secretEncrypted     String?             @map("secret_encrypted")
  /// Last 4 chars of the plain secret — safe to show in UI (e.g. "••••AB3F").
  secretMaskTail      String?             @map("secret_mask_tail") @db.VarChar(8)
  /// "Activity number" / income source sequence — issued by ISTD.
  activityNumber      String?             @map("activity_number") @db.VarChar(40)
  /// Taxpayer registration number (TIN).
  taxpayerNumber      String?             @map("taxpayer_number") @db.VarChar(40)
  /// Display name on invoices submitted to JoFotara (Arabic).
  companyName         String?             @map("company_name") @db.VarChar(200)
  /// Sandbox by default — never auto-toggle to production.
  environment         JofotaraEnvironment @default(sandbox)
  /// Override the base URL (allows pointing at a regional endpoint or proxy).
  /// Empty = use the default for the chosen environment.
  baseUrlOverride     String?             @map("base_url_override")
  /// Auto-submit every cash sale on creation. Credit sales are always queued.
  autoSendOnSale      Boolean             @default(false) @map("auto_send_on_sale")
  /// HTTP timeout per submission (ms).
  timeoutMs           Int                 @default(15000) @map("timeout_ms")
  /// Was at least one successful test connection performed?
  connectionVerifiedAt DateTime?          @map("connection_verified_at") @db.Timestamptz
  updatedAt           DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("jofotara_configs")
}

/// Each call to JoFotara is logged here for compliance + debugging.
/// Auto-pruned by a future cron to keep this table reasonable in size.
model JofotaraSubmission {
  id              BigInt              @id @default(autoincrement())
  tenantId        String              @map("tenant_id") @db.Uuid
  invoiceId       String?             @map("invoice_id") @db.Uuid
  documentType    JofotaraDocumentType @default(invoice) @map("document_type")
  /// Status of the SUBMISSION (not the invoice). An invoice can have many
  /// submissions (e.g. retry after failure).
  status          JofotaraStatus      @default(queued)
  requestXml      String?             @map("request_xml")
  responsePayload String?             @map("response_payload")
  httpStatus      Int?                @map("http_status")
  errorMessage    String?             @map("error_message")
  /// Server-side execution time in ms.
  durationMs      Int?                @map("duration_ms")
  /// User who triggered the submission (null = system/auto).
  userId          String?             @map("user_id") @db.Uuid
  createdAt       DateTime            @default(now()) @map("created_at") @db.Timestamptz

  tenant  Tenant        @relation(fields: [tenantId], references: [id])
  invoice SalesInvoice? @relation(fields: [invoiceId], references: [id])
  user    User?         @relation(fields: [userId], references: [id])

  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([invoiceId])
  @@map("jofotara_submissions")
}

model TelegramLink {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  userId          String?  @map("user_id") @db.Uuid
  telegramChatId  String?  @unique @map("telegram_chat_id") @db.VarChar(40)
  linkCode        String?  @map("link_code") @db.VarChar(12)
  isActive        Boolean  @default(false) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User?  @relation(fields: [userId], references: [id])

  @@map("telegram_links")
}

// =====================================================================
// Telegram Bot Integration (extends the pre-existing TelegramLink)
// =====================================================================

/**
 * Persistent conversation state per Telegram chat. Multi-step flows
 * (e.g. "record expense" → asks for category, branch, amount) survive
 * server restarts by keeping their state here rather than in memory.
 */
model TelegramConversation {
  id             String   @id @default(uuid()) @db.Uuid
  telegramChatId String   @unique @map("telegram_chat_id") @db.VarChar(40)
  /** Current pending flow (e.g. 'expense.awaiting_category'). null = idle. */
  state          String?  @db.VarChar(80)
  /** Free-form context — collected fields, last intent, etc. */
  context        Json     @default("{}")
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@index([updatedAt])
  @@map("telegram_conversations")
}

/**
 * Full audit trail of every incoming Telegram message we processed.
 * Used for security review, debugging, and abuse detection.
 */
model TelegramCommandLog {
  id             BigInt   @id @default(autoincrement())
  tenantId       String?  @map("tenant_id") @db.Uuid
  userId         String?  @map("user_id") @db.Uuid
  telegramChatId String   @map("telegram_chat_id") @db.VarChar(40)
  telegramUserId String?  @map("telegram_user_id") @db.VarChar(40)
  /** Detected intent (e.g. 'expense.create', 'report.sales.today'). */
  intent         String?  @db.VarChar(60)
  /** Raw text sent by the user (truncated). */
  rawText        String?  @map("raw_text") @db.VarChar(500)
  /** Extracted arguments as JSON (amounts, dates, etc.). */
  args           Json?
  /** 'ok' | 'denied' | 'error' | 'pending' */
  result         String   @db.VarChar(20)
  /** Human-readable message returned to the user (truncated). */
  reply          String?  @db.VarChar(500)
  /** Optional linked entity (expense.id, invoice.id, …). */
  entityType     String?  @map("entity_type") @db.VarChar(40)
  entityId       String?  @map("entity_id") @db.Uuid
  errorMessage   String?  @map("error_message") @db.VarChar(500)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([tenantId, createdAt])
  @@index([telegramChatId, createdAt])
  @@index([userId, createdAt])
  @@map("telegram_command_log")
}

/**
 * Notification subscriptions. A user can opt-in to receive scheduled
 * summaries (daily/weekly) and real-time alerts (low stock, big
 * expense, negative cash) at chosen times.
 */
model TelegramSubscription {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  telegramChatId String   @map("telegram_chat_id") @db.VarChar(40)
  /** 'daily_summary' | 'weekly_summary' | 'low_stock' | 'big_expense' | 'overdue_receivable' | 'due_cheque' */
  kind           String   @db.VarChar(40)
  /** For scheduled kinds: HH:MM in tenant timezone. */
  scheduleAt     String?  @map("schedule_at") @db.VarChar(5)
  /** Comma-separated: 'mon,tue,wed,thu,fri,sat,sun'. Empty = all days. */
  scheduleDays   String?  @map("schedule_days") @db.VarChar(30)
  /** Optional branch restriction. */
  branchId       String?  @map("branch_id") @db.Uuid
  /** Threshold amount for 'big_expense' etc. */
  threshold      Decimal? @db.Decimal(14, 3)
  /** Preferred language for this subscription's messages. */
  language       String?  @db.VarChar(4)
  isActive       Boolean  @default(true) @map("is_active")
  lastFiredAt    DateTime? @map("last_fired_at") @db.Timestamptz
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([tenantId, kind, isActive])
  @@index([telegramChatId])
  @@map("telegram_subscriptions")
}

// =====================================================================
// FIFO cost layers (auto-parts stores need per-branch, per-purchase
// costing so returned/damaged items don't distort profit).
// =====================================================================

/**
 * One cost layer per (purchase_item × branch). Records exactly how many
 * units are still available at that layer's cost. Sales walk layers by
 * `receivedAt ASC` and decrement `qtyRemaining`.
 *
 * We never delete layers even at qtyRemaining=0 — the row is the source
 * of truth for auditing which sale consumed what.
 */
model FifoLayer {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  branchId       String   @map("branch_id") @db.Uuid
  partId         String   @map("part_id") @db.Uuid
  /** Source purchase-item (nullable for backfill/opening-balance layers). */
  purchaseItemId String?  @unique @map("purchase_item_id") @db.Uuid
  /** Backfill/opening-balance flag — set for layers without a purchase source. */
  origin         String   @default("purchase") @db.VarChar(20)
  qtyReceived    Decimal  @map("qty_received")  @db.Decimal(12, 3)
  qtyRemaining   Decimal  @map("qty_remaining") @db.Decimal(12, 3)
  unitCost       Decimal  @map("unit_cost")     @db.Decimal(12, 3)
  receivedAt     DateTime @map("received_at")   @db.Timestamptz
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenant       Tenant             @relation(fields: [tenantId], references: [id])
  branch       Branch             @relation(fields: [branchId], references: [id])
  part         Part               @relation(fields: [partId], references: [id])
  purchaseItem PurchaseItem?      @relation(fields: [purchaseItemId], references: [id])
  consumptions FifoConsumption[]

  /** Composite index used by the "next layer to consume" query. */
  @@index([tenantId, branchId, partId, receivedAt])
  @@index([tenantId, partId])
  @@map("fifo_layers")
}

/**
 * Per-sale-line audit trail of which FIFO layers were consumed and at
 * what cost. Makes profit calculations fully explainable.
 */
model FifoConsumption {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  /** The sale line that consumed the stock. */
  salesItemId  String   @map("sales_item_id") @db.Uuid
  /** The layer that was drawn from. */
  fifoLayerId  String   @map("fifo_layer_id") @db.Uuid
  qty          Decimal  @db.Decimal(12, 3)
  unitCost     Decimal  @map("unit_cost")   @db.Decimal(12, 3)
  lineCost     Decimal  @map("line_cost")   @db.Decimal(14, 3)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  fifoLayer FifoLayer @relation(fields: [fifoLayerId], references: [id])
  salesItem SalesItem @relation(fields: [salesItemId], references: [id], onDelete: Cascade)

  @@index([tenantId, salesItemId])
  @@index([fifoLayerId])
  @@map("fifo_consumptions")
}

// =====================================================================
//  WORKSHOP MODULE — vehicles & job cards
//  Added for Option D. A job card is a repair order: parts consumed
//  atomically from stock (reusing the existing decrement + FIFO paths
//  once completed), labor lines with hours × rate, and a status
//  Kanban (draft / in_progress / waiting_parts / completed / delivered
//  / cancelled). Completed cards convert to a SalesInvoice via the
//  existing SalesService so pricing, tax, JoFotara, cost accounting,
//  and customer-balance updates all reuse tested code paths.
// =====================================================================

enum JobCardStatus {
  draft
  in_progress
  waiting_parts
  completed
  delivered
  cancelled
}

/// A vehicle belonging to a customer. Auto-parts shops often keep
/// multiple cars per customer (family / fleet). Plate + VIN are both
/// indexed for fast lookup at the counter — either can identify a car.
/// Soft-delete via `deletedAt` matches the rest of the schema.
model Vehicle {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  customerId   String    @map("customer_id") @db.Uuid
  plate        String?   @db.VarChar(30)
  vin          String?   @db.VarChar(30)
  make         String?   @db.VarChar(60)
  model        String?   @db.VarChar(80)
  year         Int?
  color        String?   @db.VarChar(40)
  engine       String?   @db.VarChar(60)
  transmission String?   @db.VarChar(30)
  mileage      Int?
  notes        String?
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])
  jobCards JobCard[]

  // Plate uniqueness scoped per-tenant — two tenants can independently
  // hold the same plate. `IF NOT NULL` semantics via a partial index in
  // Postgres is desirable, but Prisma's @@unique will suffice for
  // typical rows; empty-string plates should be stored as NULL.
  @@unique([tenantId, plate])
  @@index([tenantId, customerId])
  @@index([tenantId, vin])
  @@map("vehicles")
}

/// The heart of the workshop module. Each card is a repair order for
/// a specific customer+vehicle, opened by one user, worked by (usually)
/// one mechanic, and closed when the customer picks the car up.
///
/// Totals are derived (sum of parts + labor - discount + tax) and
/// cached on the row so lists don't need a join. They're recomputed
/// on every add/remove/edit inside a transaction.
model JobCard {
  id           String        @id @default(uuid()) @db.Uuid
  tenantId     String        @map("tenant_id") @db.Uuid
  branchId     String        @map("branch_id") @db.Uuid
  cardNo       String?       @map("card_no") @db.VarChar(40)
  customerId   String?       @map("customer_id") @db.Uuid
  vehicleId    String?       @map("vehicle_id") @db.Uuid

  complaint    String?       // customer's stated problem
  diagnosis    String?       // mechanic's finding
  workDone     String?       @map("work_done")

  mileageIn    Int?          @map("mileage_in")
  mileageOut   Int?          @map("mileage_out")

  status       JobCardStatus @default(draft)

  /// Who opened the card (usually a service advisor).
  openedBy     String?       @map("opened_by") @db.Uuid
  /// Assigned mechanic.
  mechanicId   String?       @map("mechanic_id") @db.Uuid

  openedAt     DateTime      @default(now()) @map("opened_at") @db.Timestamptz
  closedAt     DateTime?     @map("closed_at") @db.Timestamptz

  discount     Decimal       @default(0) @db.Decimal(14, 3)
  tax          Decimal       @default(0) @db.Decimal(14, 3)
  partsTotal   Decimal       @default(0) @map("parts_total") @db.Decimal(14, 3)
  laborTotal   Decimal       @default(0) @map("labor_total") @db.Decimal(14, 3)
  total        Decimal       @default(0) @db.Decimal(14, 3)

  /// Set once the card is completed and converted to a SalesInvoice.
  /// Nullable while the card is still open.
  invoiceId    String?       @unique @map("invoice_id") @db.Uuid

  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt    DateTime?     @map("deleted_at") @db.Timestamptz

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  branch       Branch        @relation(fields: [branchId], references: [id])
  customer     Customer?     @relation(fields: [customerId], references: [id])
  vehicle      Vehicle?      @relation(fields: [vehicleId], references: [id])
  opener       User?         @relation("JobCardOpenedBy", fields: [openedBy], references: [id])
  mechanic     User?         @relation("JobCardMechanic", fields: [mechanicId], references: [id])
  parts        JobCardPart[]
  labors       JobCardLabor[]
  invoice      SalesInvoice?

  @@index([tenantId, branchId, status, openedAt])
  @@index([tenantId, vehicleId])
  @@index([tenantId, customerId])
  @@map("job_cards")
}

/// A part attached to a job card. Quantity × unitPrice = lineTotal.
/// Stock is NOT deducted at add-time — a card in draft/in_progress
/// only reserves the parts logically. Deduction happens atomically
/// when the card is converted to an invoice (via SalesService), so
/// FIFO / avgCost / stock movement all funnel through the same
/// battle-tested code path.
model JobCardPart {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  jobCardId  String   @map("job_card_id") @db.Uuid
  partId     String   @map("part_id") @db.Uuid
  qty        Decimal  @db.Decimal(12, 3)
  unitPrice  Decimal  @map("unit_price") @db.Decimal(12, 3)
  discount   Decimal  @default(0) @db.Decimal(12, 3)
  lineTotal  Decimal  @map("line_total") @db.Decimal(14, 3)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  jobCard JobCard @relation(fields: [jobCardId], references: [id], onDelete: Cascade)
  part    Part    @relation(fields: [partId], references: [id])

  @@index([tenantId, jobCardId])
  @@map("job_card_parts")
}

/// A labor line. Hours × ratePerHour = lineTotal. `performedBy` is
/// optional so you can log "External bodywork" or similar without
/// having to create a User row for the outside vendor.
model JobCardLabor {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  jobCardId    String   @map("job_card_id") @db.Uuid
  description  String   @db.VarChar(300)
  hours        Decimal  @default(1) @db.Decimal(6, 2)
  ratePerHour  Decimal  @map("rate_per_hour") @db.Decimal(10, 2)
  lineTotal    Decimal  @map("line_total")    @db.Decimal(14, 3)
  performedBy  String?  @map("performed_by") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenant   Tenant  @relation(fields: [tenantId], references: [id])
  jobCard  JobCard @relation(fields: [jobCardId], references: [id], onDelete: Cascade)
  performer User?  @relation("JobCardLaborPerformer", fields: [performedBy], references: [id])

  @@index([tenantId, jobCardId])
  @@map("job_card_labors")
}
